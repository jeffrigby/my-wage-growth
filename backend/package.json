    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "zod": "^3.25.32"
  },
  "scripts": {
    "unit": "vitest run",
    "unit:watch": "vitest",
    "unit:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "prettier --write 'src/**/*.{js,ts}' && eslint --fix 'src/**/*.{js,ts}'",
    "lint:sam": "sam validate --lint",
