  "author": "SAM CLI",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.3",
    "@aws-lambda-powertools/metrics": "^2.0.3",
    "@aws-lambda-powertools/parameters": "^2.20.0",
    "@aws-lambda-powertools/parser": "^2.20.0",
    "@aws-lambda-powertools/tracer": "^2.0.3",
    "@aws-sdk/client-appconfigdata": "^3.817.0",
    "@aws-sdk/client-s3": "^3.817.0",
    "@aws-sdk/lib-storage": "^3.817.0",
    "@aws-sdk/s3-request-presigner": "^3.817.0",
