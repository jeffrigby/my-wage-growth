{
  "name": "my-wage-growth-backend",
  "version": "1.0.0",
  "description": "hello world sample for NodeJS",
  "main": "app.js",
  "repository": "https://github.com/aws/aws-sam-cli-app-templates/tree/master/nodejs22.x/hello-ts-pt",
  "author": "SAM CLI",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.3",
    "@aws-lambda-powertools/metrics": "^2.0.3",
    "@aws-lambda-powertools/parameters": "^2.20.0",
    "@aws-lambda-powertools/parser": "^2.20.0",
    "@aws-lambda-powertools/tracer": "^2.0.3",
    "@aws-sdk/client-appconfigdata": "^3.817.0",
    "@aws-sdk/client-s3": "^3.817.0",
    "@aws-sdk/lib-storage": "^3.817.0",
    "@aws-sdk/s3-request-presigner": "^3.817.0",
    "@middy/core": "^6.3.0",
    "csv-parse": "^6.1.0",
    "p-limit": "^7.1.1",
    "p-retry": "^7.1.0",
    "unzipper": "^0.12.3",
    "zod": "^4.1.12"
  },
  "scripts": {
    "unit": "vitest run",
    "unit:watch": "vitest",
    "unit:ui": "vitest --ui",
    "integration": "echo 'No real integration tests yet - use SAM local invoke for testing'",
    "test:all": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "prettier --write 'src/**/*.{js,ts}' && eslint --fix 'src/**/*.{js,ts}'",
    "lint:sam": "sam validate --lint",
    "compile": "tsc",
    "test": "npm run compile && npm run unit",
    "local-us-cpi-data": "sam build && sam local invoke GetUSCPIDataFunction -e events/get-us-cpi-data-event.json -n config/sandbox.json | jq",
    "local-canadian-cpi-data": "sam build && sam local invoke GetCanadianCPIDataFunction -e events/get-canadian-cpi-data-event.json -n config/sandbox.json | jq",
    "local-uk-cpi-data": "sam build && sam local invoke GetUKCPIDataFunction -e events/get-uk-cpi-data-event.json -n config/sandbox.json | jq"
  },
  "devDependencies": {
    "@eslint/json": "^0.14.0",
    "@types/aws-lambda": "^8.10.109",
    "@types/node": "^22.15.23",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.27.0",
    "ts-node": "^10.9.1",
    "vitest": "^4.0.14"
  }
}
